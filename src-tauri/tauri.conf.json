{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ANT",
  "version": "0.1.1",
  "identifier": "com.ant.desktop",
  "build": {
    "frontendDist": "../src-tauri/web",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "title": "ANT",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "useHttpsScheme": false,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": true,
      "wix": {
        "language": "en-US",
        "upgradeCode": "2E5C9C9C-0000-0000-0000-000000000001"
      }
    }
  }
}
