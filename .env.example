# ANT v3 — Environment Configuration
# Copy this file to .env and fill in your values

# API key for authenticating CLI and external requests (generate with: openssl rand -hex 32)
ANT_API_KEY=replace-with-openssl-rand-hex-32

# Server binding
ANT_PORT=6458
ANT_HOST=0.0.0.0

# Security: restrict to Tailscale IPs only (100.x.x.x)
ANT_TAILSCALE_ONLY=false
ANT_ALLOW_LOOPBACK=true

# Admin bearer token for privileged write endpoints (catalogue mutations,
# terminal adopt, reclaim). Generate with: openssl rand -hex 32
# Requests to POST/PUT/DELETE /api/default-models, /api/default-agent-kinds,
# /api/terminals/:id/adopt, etc. must send `Authorization: Bearer <this>`.
# GET on those routes stays public (read-only catalogue). When unset, the
# admin gate denies all privileged writes (fail-closed), so set this before
# seeding catalogues or adopting terminals.
# ANT_ADMIN_TOKEN=replace-with-openssl-rand-hex-32

# Demo LOGIN identity handle. This is the handle the demo-login endpoint
# BINDS the browser session to — it gets written into author_handle,
# memberships, and whoCreatedIt, i.e. it IS the operator's internal truth.
# Keep it at the @you default. Do NOT set it to @JWPK: that would make
# @JWPK the stored identity (sentinel), not a display alias. To change only
# what's SHOWN, use ANT_OPERATOR_DISPLAY_HANDLE below instead.
# ANT_DEMO_HANDLE=@you

# Operator DISPLAY handle (OUT-only render alias). The internal operator
# identity stays the @you sentinel (load-bearing in whoCreatedIt / kind
# detection / inbox-edge / auth-bypass — never rewritten). This var only
# changes the OUTBOUND label: operatorDisplayHandle() maps @you → this value
# at the serialization boundary (message authorDisplayName, member
# displayName) and the UI suppresses the canonical @you subscript. Unset =
# no mapping (@you shown as-is). Set to @JWPK for the demo roster.
# ANT_OPERATOR_DISPLAY_HANDLE=@JWPK

# Root directory for project browsing (optional)
ANT_ROOT_DIR=/Users/you/projects

# Obsidian vault path for session export (optional)
ANT_OBSIDIAN_VAULT=/Users/you/vault

# Built Stage deck roots (optional).
# Deck source and generated dist output live outside this repo. Each deck is
# served from <root>/<slug>/dist/index.html via /d/:slug. Roots can be Dropbox,
# iCloud Drive, mounted shares, or any other local filing system. Separate
# multiple roots with ":" on macOS/Linux.
#
# Example with a path containing spaces:
# ANT_BUILT_DECKS_ROOTS="/Users/you/Dropbox/Decks/ANTdecks"
ANT_BUILT_DECKS_ROOTS=/Users/you/ANTdecks

# TLS certificates (optional — required for HTTPS)
ANT_TLS_CERT=./certs/ant-tls.crt
ANT_TLS_KEY=./certs/ant-tls.key

# Public server URL for share links and CLI instructions.
# Set this to your Tailscale hostname or public URL for remote access.
# IMPORTANT: on plain-HTTP deployments this is also used to derive ORIGIN
# (see below) — match the protocol you actually serve on.
# ANT_SERVER_URL=https://your-hostname:6458

# SvelteKit adapter-node ORIGIN. Browser /api/* writes are gated on
# Origin === computed-origin; adapter-node defaults the protocol to "https"
# when this is unset, which 401s every plain-HTTP browser POST. server.ts
# auto-falls-back to ANT_SERVER_URL — set ORIGIN explicitly only if you
# need a different value (e.g. behind a reverse proxy or accessing via IP).
# ORIGIN=http://your-hostname:6458

# Externally-routable origin for invite share strings. Use this when the
# server binds to a private port (e.g. :6458 on Tailnet) but joiners reach
# it via a public reverse proxy / Tailscale Funnel on 443. Host-only, no
# port. If unset, falls back to ANT_SERVER_URL.
# ANT_PUBLIC_ORIGIN=https://your-hostname.ts.net

# Storage root for SQLite db, transcripts, fingerprint state, etc.
# Defaults to $HOME/.ant-v3
# ANT_DATA_DIR=/Users/you/.ant-v3

# Cap on concurrent active agent sessions. 0 = unlimited.
# ANT_MAX_ACTIVE_AGENTS=0

# Max consecutive failed invite-exchange attempts before the invite is locked.
# Counter resets on success. Default: 5
# ANT_INVITE_MAX_FAILURES=5

# ── Session recovery after a reboot ────────────────────────────────────
# A Mac restart kills the tmux server + every agent CLI (the SQLite DB and
# this server survive). The /terminals "Recover" buttons and
# `ant sessions recover` rebuild sessions on demand. To make recovery
# hands-off, set ANT_AUTORECOVER_SESSIONS=1 — on boot the server recreates
# every dead session's tmux pane in its original cwd and rebinds identity.
# ANT_AUTORECOVER_SESSIONS=0
#
# Also relaunch the agent CLI (retype the captured launch command into each
# pane). Higher-stakes than recreating panes, so it's a separate opt-in and
# only takes effect when ANT_AUTORECOVER_SESSIONS is also on.
# ANT_AUTORECOVER_AGENTS=0

# ── Interview-Lite voice mode (docs/INTERVIEW-LITE.md) ─────────────────
# Optional ElevenLabs key for higher-quality TTS in interview modals.
# When unset, /api/voice/elevenlabs reports available:false and the modal
# falls back to browser SpeechSynthesis (free, robotic). When set, the
# server proxies audio bytes via /api/voice/elevenlabs so the key never
# reaches the browser.
# ELEVENLABS_API_KEY=sk_...

# Optional voice id used as the global default for the proxy. Falls back
# to ElevenLabs "Rachel" (21m00Tcm4TlvDq8ikWAM) when unset. Override per
# request by passing { voice_id } in the POST body.
# ELEVENLABS_DEFAULT_VOICE_ID=

# Optional model override. Defaults to eleven_turbo_v2_5 (latency-
# optimised). Bump to eleven_multilingual_v2 for higher fidelity.
# ELEVENLABS_DEFAULT_MODEL_ID=eleven_turbo_v2_5
