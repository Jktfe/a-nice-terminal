# ANT v3 — Environment Configuration
# Copy this file to .env and fill in your values

# API key for authenticating CLI and external requests (generate with: openssl rand -hex 32)
ANT_API_KEY=your-secret-api-key

# Server binding
ANT_PORT=6458
ANT_HOST=0.0.0.0

# Security: restrict to Tailscale IPs only (100.x.x.x)
ANT_TAILSCALE_ONLY=false
ANT_ALLOW_LOOPBACK=true

# Root directory for project browsing (optional)
ANT_ROOT_DIR=/Users/you/projects

# Obsidian vault path for session export (optional)
ANT_OBSIDIAN_VAULT=/Users/you/vault

# TLS certificates (optional — required for HTTPS)
ANT_TLS_CERT=./certs/ant-tls.crt
ANT_TLS_KEY=./certs/ant-tls.key

# Public server URL for share links and CLI instructions
# Set this to your Tailscale hostname or public URL for remote access
# ANT_SERVER_URL=https://your-hostname:6458

# Externally-routable origin for invite share strings. Use this when the
# server binds to a private port (e.g. :6458 on Tailnet) but joiners reach
# it via a public reverse proxy / Tailscale Funnel on 443. Host-only, no
# port. If unset, falls back to ANT_SERVER_URL.
# ANT_PUBLIC_ORIGIN=https://your-hostname.ts.net
