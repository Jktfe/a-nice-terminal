# ANT Configuration
# Port to run on (default: 3000)
ANT_PORT=3000

# Host to bind HTTP and WebSocket listeners (default: 0.0.0.0)
ANT_HOST=0.0.0.0

# Restrict network access to Tailscale/explicit allowlist.
# Set to false to disable strict allowlist behavior.
ANT_TAILSCALE_ONLY=true

# Optional allowlist entries (CIDR or IP), comma-separated.
# Example: 100.64.0.0/10,127.0.0.1/32,10.0.0.0/8
ANT_ALLOWLIST=

# Allow loopback traffic for local-only testing.
ANT_ALLOW_LOOPBACK=false

# Optional API key for agent authentication
# If set, agents must include this in X-API-Key header or Bearer token
# ANT_API_KEY=your-secret-key

# Optional Vite-exposed key for browser frontend Socket.IO/API auth
VITE_ANT_API_KEY=

# Default working directory for new terminal sessions (default: $HOME)
# ANT_ROOT_DIR=~/CascadeProjects

# Kill timer grace period in milliseconds for idle terminal sessions (default: 900000 = 15 min)
# ANT_SESSION_TTL_MS=900000

# ── Chairman Orchestration (all optional) ─────────────────────────────────────

# How often the terminal monitor polls PTY screens for permission prompts (ms)
# TERMINAL_MONITOR_POLL_MS=2000

# How often the message bridge polls chat for undelivered @mentions (ms)
# MESSAGE_BRIDGE_POLL_MS=3000

# Grace period before injecting a message into a terminal (ms)
# MESSAGE_BRIDGE_GRACE_MS=6000

# Task watchdog thresholds
# WATCHDOG_IDLE_MS=300000       # 5 min idle before nudging an in-progress task
# WATCHDOG_UNSTARTED_MS=180000  # 3 min before alerting on an unstarted assigned task
# WATCHDOG_SILENT_MS=900000     # 15 min without a chat update before alerting
# WATCHDOG_COOLDOWN_MS=600000   # 10 min cooldown between nudges per task
