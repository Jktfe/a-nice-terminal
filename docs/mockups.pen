                                    {
                                      "type": "text",
                                      "id": "sOZM9",
                                      "name": "codeLine2",
                                      "fill": "#6B7F95",
                                      "content": "  private interval: NodeJS.Timer;",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "XtCuc",
                                      "name": "codeLine3",
                                      "fill": "#6B7F95",
                                      "content": "  private readonly PING_INTERVAL = 30_000;",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "pCW9O",
                                      "name": "codeLine4",
                                      "fill": "#6B7F95",
                                      "content": " ",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "Xzwmk",
                                      "name": "codeLine5",
                                      "fill": "#22D3EE",
                                      "content": "  start(pool: ConnectionPool) {",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "dymZ1",
                                      "name": "codeLine6",
                                      "fill": "#C8D4E0",
                                      "content": "    this.interval = setInterval(() => {",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "xp7ti",
                                      "name": "codeLine7",
                                      "fill": "#C8D4E0",
                                      "content": "      pool.connections.forEach(c => c.ping());",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "ZxdZE",
                                      "name": "codeLine8",
                                      "fill": "#C8D4E0",
                                      "content": "    }, this.PING_INTERVAL);",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "pNbDi",
                                      "name": "codeLine9",
                                      "fill": "#8899AA",
                                      "content": "  }",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "ZU6Oy",
                                      "name": "codeLine10",
                                      "fill": "#8899AA",
                                      "content": "}",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    }
                                  ]
                                }
                              ]
                            },
