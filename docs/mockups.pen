                              ]
                            },
                            {
                              "type": "text",
                              "id": "hUljz",
                              "name": "msg2Para1",
                              "fill": "#1E293B",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "I can see the WebSocket handler. The main issue is that heartbeat and connection pooling are tightly coupled. Here's a cleaner approach using a separate HeartbeatManager class:",
                              "lineHeight": 1.5,
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "lYxrY",
                              "name": "Code Block",
                              "width": "fill_container",
                              "fill": "#F1F5F9",
                              "cornerRadius": 12,
                              "layout": "vertical",
                              "children": [
                                {
                                  "type": "frame",
                                  "id": "jaEbE",
                                  "name": "codeHeader",
                                  "width": "fill_container",
                                  "fill": "#E2E8F0",
                                  "cornerRadius": [
                                    12,
                                    12,
                                    0,
                                    0
                                  ],
                                  "gap": 8,
                                  "padding": [
                                    8,
                                    12
                                  ],
                                  "alignItems": "center",
                                  "children": [
                                    {
                                      "type": "text",
                                      "id": "cBzoY",
                                      "name": "codeLang",
                                      "fill": "#94A3B8",
                                      "content": "typescript",
                                      "fontFamily": "Inter",
                                      "fontSize": 11,
                                      "fontWeight": "500"
                                    },
                                    {
                                      "type": "frame",
                                      "id": "lP68v",
                                      "name": "codeSpacer",
                                      "width": "fill_container",
                                      "height": 1,
                                      "layout": "none"
                                    },
                                    {
                                      "type": "icon_font",
                                      "id": "FqGbR",
                                      "name": "codeCopy",
                                      "width": 14,
                                      "height": 14,
                                      "iconFontName": "copy",
                                      "iconFontFamily": "lucide",
                                      "fill": "#94A3B8"
                                    }
                                  ]
                                },
                                {
                                  "type": "frame",
                                  "id": "YrS8v",
                                  "name": "codeBody",
                                  "width": "fill_container",
                                  "layout": "vertical",
                                  "gap": 2,
                                  "padding": 12,
                                  "children": [
                                    {
                                      "type": "text",
                                      "id": "yTsi7",
                                      "name": "codeLine1",
                                      "fill": "#64748B",
                                      "content": "class HeartbeatManager {",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "PjYIC",
                                      "name": "codeLine2",
                                      "fill": "#64748B",
                                      "content": "  private interval: NodeJS.Timer;",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "PaU2q",
                                      "name": "codeLine3",
                                      "fill": "#64748B",
                                      "content": "  private readonly PING_INTERVAL = 30_000;",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "u3dX3",
                                      "name": "codeLine4",
                                      "fill": "#64748B",
                                      "content": " ",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "Kjsau",
                                      "name": "codeLine5",
                                      "fill": "#0891B2",
                                      "content": "  start(pool: ConnectionPool) {",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "dNR8e",
                                      "name": "codeLine6",
                                      "fill": "#1E293B",
                                      "content": "    this.interval = setInterval(() => {",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "Wm2aR",
                                      "name": "codeLine7",
                                      "fill": "#1E293B",
                                      "content": "      pool.connections.forEach(c => c.ping());",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "sIpAb",
                                      "name": "codeLine8",
                                      "fill": "#1E293B",
                                      "content": "    }, this.PING_INTERVAL);",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "sT2xs",
                                      "name": "codeLine9",
                                      "fill": "#64748B",
                                      "content": "  }",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    },
                                    {
                                      "type": "text",
                                      "id": "yb5u1",
                                      "name": "codeLine10",
                                      "fill": "#64748B",
                                      "content": "}",
                                      "fontFamily": "JetBrains Mono",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "DLdaG",
                              "name": "msg2Para2",
                              "fill": "#1E293B",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "This decouples the heartbeat logic so you can test it independently. You'd then inject it into your WebSocket server setup. Want me to also refactor the pool cleanup logic?",
                              "lineHeight": 1.5,
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
