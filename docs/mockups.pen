                                  "id": "xpCK9",
                                  "name": "name4",
                                  "fill": "#22D3EE",
                                  "content": "Claude",
                                  "fontFamily": "Inter",
                                  "fontSize": 13,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "0EA3i",
                                  "name": "time4",
                                  "fill": "#4A5C6E",
                                  "content": "2:36 PM",
                                  "fontFamily": "Inter",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "ghBSt",
                              "name": "msg4Para1",
                              "fill": "#C8D4E0",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Good catch — there is indeed a race condition. When multiple clients disconnect at once, the pool's drain method can be called re-entrantly. Here's the fix using a mutex guard:",
                              "lineHeight": 1.5,
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "z7pCy",
                              "name": "Code Block 2",
                              "width": "fill_container",
                              "fill": "#0A0F14",
                              "cornerRadius": 12,
                              "layout": "vertical",
                              "padding": 16,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "aPonI",
                                  "name": "codeText",
                                  "fill": "#A3BFDB",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "class PoolManager {\n  private mutex = new Mutex();\n\n  async drain(): Promise<void> {\n    await this.mutex.runExclusive(async () => {\n      if (this.drained) return;\n      this.drained = true;\n      await this.releaseAll();\n    });\n  }\n}",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "3bE7f",
                              "name": "msg4Para2",
                              "fill": "#C8D4E0",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "The mutex ensures only one drain call executes at a time. This eliminates the 'pool already drained' warnings you're seeing in the logs.",
                              "lineHeight": 1.5,
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
