{
  "name": "a-nice-terminal",
  "private": true,
  "version": "0.1.0",
  "description": "A web and API interface for terminal and conversation sessions, with MCP integration for humans and AI agents",
  "license": "MIT",
  "workspaces": [
    "packages/app",
    "packages/mcp",
    "packages/website"
  ],
  "scripts": {
    "dev": "cd packages/app && npx tsx server/index.ts",
    "build": "bun run --filter '@ant/app' build",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test",
    "test:app": "cd packages/app && npx vitest run",
    "test:mcp": "cd packages/mcp && npx vitest run"
  },
  "devDependencies": {
    "node-gyp": "^12.2.0",
    "vitest": "^3.2.3"
  }
}
