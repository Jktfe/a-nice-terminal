{
  "name": "ant-v3",
  "version": "0.2.0",
  "description": "Self-hosted multi-agent terminal orchestrator that coordinates multiple AI CLIs (Claude Code, Gemini CLI, Codex, Copilot, Ollama, and more) through shared sessions, persistent chat, and convention-based protocols.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jktfe/a-nice-terminal.git"
  },
  "homepage": "https://github.com/Jktfe/a-nice-terminal#readme",
  "bugs": {
    "url": "https://github.com/Jktfe/a-nice-terminal/issues"
  },
  "keywords": [
    "terminal",
    "ai",
    "agents",
    "multi-agent",
    "claude",
    "gemini",
    "codex",
    "ollama",
    "tmux",
    "websocket",
    "sveltekit",
    "pty"
  ],
  "author": "James King <j.w.p.king@gmail.com> (https://github.com/Jktfe)",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.4 <21",
    "bun": ">=1.1.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "postbuild": "lsof -ti TCP:${ANT_PORT:-6458} | xargs kill -TERM 2>/dev/null && sleep 1 && nohup node --import ./node_modules/tsx/dist/esm/index.mjs ./server.ts >> /tmp/ant-server.log 2>&1 & disown || true",
    "preview": "vite preview",
    "start": "node --import ./node_modules/tsx/dist/esm/index.mjs ./server.ts",
    "start:prod": "npm run build && npm run start",
    "dev:full": "lsof -ti TCP:6458 | xargs kill -TERM 2>/dev/null; concurrently -n vite,server -c cyan,green \"vite build --watch\" \"nodemon --watch build --delay 1.5 --exec 'node --import ./node_modules/tsx/dist/esm/index.mjs ./server.ts'\"",
    "daemon:start": "node --import ./node_modules/tsx/dist/esm/index.mjs ./src/lib/server/pty-daemon.ts &",
    "daemon:stop": "node -e \"const fs=require('fs'); const p=(process.env.HOME||'/tmp')+'/.ant/pty-daemon.lock'; try { const pid=Number(fs.readFileSync(p,'utf8')); if (pid) process.kill(pid,'SIGTERM'); } catch {}\"",
    "idle-tick": "bun scripts/idle-tick.ts",
    "fingerprint": "tsx src/fingerprint/runner.ts",
    "fingerprint:claude": "tsx src/fingerprint/runner.ts --agent claude-code",
    "fingerprint:gemini": "tsx src/fingerprint/runner.ts --agent gemini-cli",
    "fingerprint:codex": "tsx src/fingerprint/runner.ts --agent codex-cli",
    "fingerprint:all": "tsx src/fingerprint/runner.ts --all",
    "fingerprint:list": "tsx src/fingerprint/runner.ts --list",
    "test": "npx svelte-kit sync 2>/dev/null; vitest run",
    "test:watch": "vitest",
    "test:integration": "ANT_TEST_URL=${ANT_TEST_URL:-https://localhost:6458} vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.11.0",
    "marked": "^17.0.6",
    "nanoid": "^5.1.7",
    "node-pty": "^1.1.0",
    "strip-ansi": "^7.2.0",
    "svelte": "^5.55.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  }
}
