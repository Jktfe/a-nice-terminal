src-tauri/binaries/


# Agent-spawned worktree dirs (per-session, ephemeral)
.claude/worktrees/
.worktrees/

# Operator-deployed launchd plists may carry absolute home paths,
# node-bin paths, and secrets-env paths that should never land in
# the OSS history. The `.template` shipped variant has placeholders
# operators substitute; the live file stays local.
deploy/com.ant.fresh.plist
deploy/*.plist
!deploy/*.plist.template

# Editor + tooling crud
.idea/
.vscode/
*.swp
*~

# Backup files (any .bak, .bak-YYYY-MM-DD, .bak-pre-foo, etc)
*.bak
*.bak-*

# OS noise
Thumbs.db
ehthumbs.db
Desktop.ini

# Account-strategy deck artefacts — user-management discussion is OUT of
# OSS scope (per JWPK msg_l3l92803r9 + users-room convergence with
# @usermgtclaude). Slides live on disk + are served via the local
# launchd OSS server but MUST NOT ship in the public OSS repo.
static/artefacts/jfeboje2kj/

# Antigravity CLI runtime state (per-session UUID files; not source)
.antigravitycli/
node_modules

# Playwright codegen capture artifacts — regeneratable test-debug cruft + PII surface (2026-06-01)
.playwright-cli/

# Internal ANT working docs / coordination — created OUTSIDE the OSS repo (2026-06-01).
# Kept on disk locally, never committed: prevents accidental confidential pushes
# + accidental commits of others' internal notes.
docs/*
!docs/about-clis/
!docs/about-clis/**
agents-pitch/
POSITIONING.md
_pending-slices/
.claude/
test-api.cjs

# External asset policy (JWPK msg_7nqg8oaufo): served/generated images
# must NOT live in the repo (OSS-leak risk); they live in
# ~/.ant/asset-folders.json pointed at an external folder, and a user can
# add files by hand.
# Hard-blocks new generated image commits while preserving checked-in
# brand assets that are source material.
/*.jpeg
/*.jpg
/*.png
/*.gif
/*.webp
/*.avif
# Captures live in research-site / external, not the repo
/static/captures/

# Enumerated leak dirs (private-image guard, 2026-06-10): accidents
# land in scratch / captures / diagnostics / output / agent-generated,
# NOT in an umbrella "unsynced" folder. Each rule is paired with its
# WHY-THIS-DIR comment on the line ABOVE (gitignore: only `\#` at the
# start of a line is a comment; an inline `#` after the pattern is
# folded into the pattern and matches nothing — the 8b8ef9f bug).
# generated images, served via /api/assets
/static/llm-generated/
# screenshot/UI-capture output
/static/diagnostics/
# ad-hoc agent working files; not app content
/static/scratch/
# operator local screen captures
/static/local-screenshots/
# export/transform pipeline output
/static/output/
# (existing /static/captures/ kept, not duplicated; existing
# /static/artefacts/ kept, not duplicated)
# generated manual screenshots, served via /api/assets/manual/
/static/manual/
# generated deck exports, served via /api/assets/decks/
/static/decks/**/*.png
# generated codex-about hero, served via /api/assets/codex-about-assets/
/static/codex-about-assets/*.png
# generated root output, served via /api/assets/output/
/output/*.png

# Format hole: the existing `/*.<ext>` list above covers jpeg/jpg/png/
# gif/webp/avif. Add the remaining binary image formats that can land at
# repo root (none are legit at root).
/*.bmp
/*.tiff
/*.tif
/*.heic
/*.heif
/*.raw

# Pi CLI agent-local config (not repo content; sibling of .qwen/.claude)
.pi/
