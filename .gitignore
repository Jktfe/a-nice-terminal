src-tauri/binaries/


# Agent-spawned worktree dirs (per-session, ephemeral)
.claude/worktrees/
.worktrees/

# Operator-deployed launchd plists may carry absolute home paths,
# node-bin paths, and secrets-env paths that should never land in
# the OSS history. The `.template` shipped variant has placeholders
# operators substitute; the live file stays local.
deploy/com.ant.fresh.plist
deploy/*.plist
!deploy/*.plist.template

# Editor + tooling crud
.idea/
.vscode/
*.swp
*~

# Backup files (any .bak, .bak-YYYY-MM-DD, .bak-pre-foo, etc)
*.bak
*.bak-*

# OS noise
Thumbs.db
ehthumbs.db
Desktop.ini

# Account-strategy deck artefacts — user-management discussion is OUT of
# OSS scope (per JWPK msg_l3l92803r9 + users-room convergence with
# @usermgtclaude). Slides live on disk + are served via the local
# launchd OSS server but MUST NOT ship in the public OSS repo.
static/artefacts/jfeboje2kj/

# Antigravity CLI runtime state (per-session UUID files; not source)
.antigravitycli/
node_modules

# Playwright codegen capture artifacts — regeneratable test-debug cruft + PII surface (2026-06-01)
.playwright-cli/

# Internal ANT working docs / coordination — created OUTSIDE the OSS repo (2026-06-01).
# Kept on disk locally, never committed: prevents accidental confidential pushes
# + accidental commits of others' internal notes.
docs/*
!docs/about-clis/
!docs/about-clis/**
agents-pitch/
POSITIONING.md
_pending-slices/
.claude/
test-api.cjs

# External asset policy (JWPK msg_7nqg8oaufo): served images must NOT live
# in the repo (OSS-leak risk); they live in ~/.ant/asset-folders.json
# pointed at an external folder, and a user can add files by hand.
# Hard-blocks new commits of image binaries at the repo root + in
# static/ (the static/ fallback chain's last layer is allowed; existing
# files are fine, but new top-level/ root .jp[e]g/.png/.gif/.webp/.avif
# commits are denied to stop accidental re-eviction).
/*.jpeg
/*.jpg
/*.png
/*.gif
/*.webp
/*.avif
# Captures live in research-site / external, not the repo
/static/captures/
