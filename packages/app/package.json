{
  "name": "@ant/app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx server/index.ts",
    "start": "node --env-file=../../.env --import tsx server/index.ts",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "setup:launchd": "SCRIPTS_DIR=$(cd ../../scripts && pwd) && sed \"s|__SCRIPTS_DIR__|$SCRIPTS_DIR|g\" ../../scripts/com.ant.server.plist > ~/Library/LaunchAgents/com.ant.server.plist && launchctl load ~/Library/LaunchAgents/com.ant.server.plist && echo 'ANT launchd agent installed and loaded'",
    "teardown:launchd": "launchctl unload ~/Library/LaunchAgents/com.ant.server.plist 2>/dev/null; rm -f ~/Library/LaunchAgents/com.ant.server.plist && echo 'ANT launchd agent removed'"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@tiptap/extension-code-block-lowlight": "^2.11.0",
    "@tiptap/extension-mention": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@tiptap/suggestion": "^2.11.0",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.21.2",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nanoid": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "happy-dom": "^18.0.1",
    "supertest": "^7.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^3.2.3"
  }
}
