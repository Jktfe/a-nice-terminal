# ANT — A Nice Terminal
# Copy to .env and customise for your setup

# ─── Server ───────────────────────────────────────────
ANT_PORT=3000
ANT_HOST=0.0.0.0

# Security: restrict to Tailscale network by default
# ANT_TAILSCALE_ONLY=true
# ANT_ALLOWLIST=192.168.1.0/24
# ANT_ALLOW_LOOPBACK=false

# Optional API key (if set, all clients must provide it)
# ANT_API_KEY=your-secret-key

# Default directory for new terminal sessions
# ANT_ROOT_DIR=~/projects

# Session TTL when no clients are connected (default 48h)
# ANT_SESSION_TTL_MS=172800000

# ─── Chat Sidecar ────────────────────────────────────
# ANT_CHAT_HOST=127.0.0.1
# ANT_CHAT_PORT=6464

# ─── V2 Feature Flags (all default to true) ──────────
# Set to "false" to disable

# Push notifications via ntfy.sh
# ANT_ENABLE_NOTIFICATIONS=true

# Auto-discover local AI models on startup
# ANT_ENABLE_AUTO_DISCOVER=true

# Dangerous command warnings before execution
# ANT_ENABLE_DANGER_CHECKS=true

# Auto error pattern extraction (self-learning)
# ANT_ENABLE_KNOWLEDGE=true

# Auto preference learning from command patterns
# ANT_ENABLE_PREFERENCE_LEARNING=true

# ─── Notifications ────────────────────────────────────
# Channel: "beeper" (recommended), "ntfy", or "both"
# ANT_NOTIFY_VIA=beeper

# ntfy.sh (legacy — use Beeper instead)
# NTFY_URL=https://ntfy.sh
# NTFY_TOPIC=your-topic-name

# Beeper notification chat (send notifications to this chat)
# ANT_NOTIFY_CHAT_ID=your-beeper-chat-id

# ─── Beeper (unified messaging) ──────────────────────
# Replaces per-platform adapters with one integration
# ANT_ENABLE_BEEPER=true
# BEEPER_URL=http://localhost:23373
# BEEPER_CHAT_IDS=chatid1,chatid2  (empty = manual mapping via API)
# Auth is handled via OAuth PKCE — no token env var needed

# ─── Auto-Discovery ──────────────────────────────────
# Additional model endpoints to probe (format: name:port,name:port)
# ANT_DISCOVER_PORTS=mymodel:9999,another:7777

# Set to false to skip built-in port list (Ollama, LM Studio, etc.)
# ANT_DISCOVER_BUILTIN=true

# ─── Obsidian Integration ────────────────────────────
# ANT_OBSIDIAN_VAULT=~/Obsidian/MyVault

# ─── Bridge (Telegram) ───────────────────────────────
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_AGENTS=agentId|directToken|relayToken|sessionId

# Bridge model endpoints (format: name:port,name:port)
# BRIDGE_OPENAI_ENDPOINTS=ollama:11434,lmstudio:1234
