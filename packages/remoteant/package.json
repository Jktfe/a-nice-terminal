{
  "name": "@jktfe/remoteant",
  "version": "0.1.0",
  "description": "Personal MCP gateway — local stdio adapter for antchat-mac",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "remoteant": "dist/cli.js"
  },
  "scripts": {
    "build": "node scripts/build-version.mjs && bun build --target=node --outdir=dist src/cli.ts",
    "build:dev": "node scripts/build-version.mjs && bun build --target=node --outdir=dist src/cli.ts",
    "test": "../../node_modules/.bin/vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "vitest": "^4.1.8",
    "@types/node": "^20.12.0"
  }
}
